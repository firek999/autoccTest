# API 服务 dev 模式容器
FROM python:3.12-slim

WORKDIR /app

# 安装 uv
COPY --from=ghcr.io/astral-sh/uv:0.6.14 /uv /usr/local/bin/uv

# 复制依赖声明
COPY pyproject.toml ./

# 安装依赖
RUN uv sync --no-install-project

# 源码通过 compose 卷挂载，此处不复制

EXPOSE 8000

CMD ["uv", "run", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
