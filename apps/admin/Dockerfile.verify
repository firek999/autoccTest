# 管理台 verify 模式容器
FROM node:22-alpine

WORKDIR /app

# 安装 pnpm
RUN corepack enable && corepack prepare pnpm@10.8.0 --activate

# 复制全部源码和依赖声明
COPY package.json pnpm-lock.yaml ./
COPY src/ ./src/
COPY public/ ./public/
COPY index.html tsconfig.json tsconfig.node.json vite.config.ts ./

# 安装依赖
RUN pnpm install --frozen-lockfile

# 机械验证：typecheck → lint → build → test
RUN pnpm typecheck
RUN pnpm lint
RUN pnpm build
RUN pnpm test
