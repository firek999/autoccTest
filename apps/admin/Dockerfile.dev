# 管理台 dev 模式容器
FROM node:22-alpine

WORKDIR /app

# 安装 pnpm
RUN corepack enable && corepack prepare pnpm@10.8.0 --activate

# 复制依赖声明和配置文件
COPY package.json ./
COPY index.html ./
COPY tsconfig.json tsconfig.node.json ./
COPY vite.config.ts vitest.config.ts ./
COPY eslint.config.js prettier.config.js ./

# 安装依赖
RUN pnpm install

# src/ 通过 compose 卷挂载，支持热重载

EXPOSE 5173

CMD ["pnpm", "dev", "--host", "0.0.0.0"]
